{
	"name": "typescript-action",
	"version": "0.0.0",
	"private": true,
	"description": "GitHub Actions TypeScript template",
	"keywords": [
		"actions"
	],
	"homepage": "https://github.com/actions/typescript-action",
	"bugs": {
		"url": "https://github.com/actions/typescript-action/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/actions/typescript-action.git"
	},
	"license": "MIT",
	"author": "",
	"type": "module",
	"exports": {
		".": "./dist/index.mjs"
	},
	"scripts": {
		"all": "pnpm check:fix && pnpm test && pnpm coverage && pnpm package",
		"bundle": "pnpm check:fix && pnpm package",
		"check": "biome check",
		"check:fix": "biome format --write",
		"coverage": "pnpx make-coverage-badge --output-path ./badges/coverage.svg",
		"local-action": "pnpx @github/local-action . src/main.ts .env",
		"package": "pnpm tsdown",
		"package:watch": "pnpm tsdown --watch",
		"test": "vitest",
		"w": "vitest watch"
	},
	"dependencies": {
		"@actions/core": "^3.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.11",
		"@github/local-action": "^6.0.2",
		"@repobuddy/biome": "^2.2.0",
		"@types/node": "^24.10.1",
		"make-coverage-badge": "^1.2.0",
		"tsdown": "^0.19.0-beta.2",
		"typescript": "^5.9.3",
		"vitest": "^4.0.16"
	},
	"packageManager": "pnpm@10.27.0",
	"engines": {
		"node": ">=24.0.0"
	}
}
